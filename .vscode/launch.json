{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MemCST-VSR: Train (from full/Wan2.1-T2V-1.3B.sh)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/examples/wanvideo/model_training/train.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "subProcess": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CUDA_VISIBLE_DEVICES": "0"
      },
      "args": [
        "--dataset_base_path", "/project/bamboofan/Adobe240/frame/train",
        "--dataset_metadata_path", "/project/bamboofan/Adobe240/frame/train/metadata_overfit.jsonl",
        "--val_dataset_base_path", "/project/bamboofan/Adobe240/frame/train",
        "--val_dataset_metadata_path", "/project/bamboofan/Adobe240/frame/train/metadata_overfit.jsonl",
        "--dataset_repeat", "100",
        "--space_scale", "4",
        "--time_scale", "8",
        "--rope_mode", "4d",
        "--height", "480",
        "--width", "832",
        "--model_id_with_origin_paths", "Wan-AI/Wan2.1-T2V-1.3B:diffusion_pytorch_model*.safetensors,Wan-AI/Wan2.1-T2V-1.3B:models_t5_umt5-xxl-enc-bf16.pth,Wan-AI/Wan2.1-T2V-1.3B:Wan2.1_VAE.pth",
        "--learning_rate", "1e-5",
        "--num_epochs", "100",
        "--remove_prefix_in_ckpt", "pipe.dit.",
        "--output_path", "./models/train/Wan2.1-T2V-1.3B_full",
        "--trainable_models", "dit",
        "--use_gradient_checkpointing",
        "--save_steps", "1000",
        "--validation_steps", "1000"
      ]
    },
    {
      "name": "MemCST-VSR: Inference (from inference.sh)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/examples/wanvideo/model_training/inference.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "subProcess": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "CUDA_VISIBLE_DEVICES": "0"
      },
      "args": [
        "--dataset_base_path", "/project/bamboofan/Adobe240/frame/train",
        "--dataset_metadata_path", "/project/bamboofan/Adobe240/frame/train/metadata_overfit.jsonl",
        "--data_file_keys", "image,video,frames",
        "--space_scale", "4",
        "--time_scale", "8",
        "--rope_mode", "4d",
        "--height", "480",
        "--width", "832",
        "--model_id_with_origin_paths", "Wan-AI/Wan2.1-T2V-1.3B:diffusion_pytorch_model*.safetensors,Wan-AI/Wan2.1-T2V-1.3B:models_t5_umt5-xxl-enc-bf16.pth,Wan-AI/Wan2.1-T2V-1.3B:Wan2.1_VAE.pth",
        "--dit_checkpoint", "./models/train/Wan2.1-T2V-1.3B_full/step-10000.safetensors",
        "--output_path", "./models/train/Wan2.1-T2V-1.3B_full/inference",
        "--num_inference_steps", "50",
        "--cfg_scale", "1.0",
        "--sigma_shift", "5.0",
        "--seed", "0",
        "--fps", "15",
        "--quality", "5",
        "--tiled"
      ]
    }
  ]
}
